# OC Public Services — API Environment Variables
# Copy to .env and fill in values

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# Oracle Autonomous DB (mTLS wallet)
ORACLE_WALLET_DIR=/app/wallet
ORACLE_DSN=ocpublic_medium
ORACLE_USER=ocpublic
ORACLE_PASSWORD=change-me

# Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
